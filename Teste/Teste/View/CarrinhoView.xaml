<UserControl x:Class="CestaApp.Views.CarrinhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F2F2">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Seu Carrinho de Compras" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="450">
                <ItemsControl ItemsSource="{Binding ItensNoCarrinho}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#F3F4F6" Width="80" Height="80" CornerRadius="8" Margin="0,0,15,0">
                                        <Image Source="{Binding CestaSelecionada.ImagemCompleta}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                        <TextBlock Text="{Binding CestaSelecionada.Nome}" FontWeight="Bold" FontSize="18"/>

                                        <TextBlock Foreground="#555" FontSize="13" TextWrapping="Wrap" Margin="0,5,0,0">
                                        <Run Text="Contém: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding CestaSelecionada.ResumoItens, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Observacoes}" Foreground="#888" FontStyle="Italic" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Subtotal, StringFormat='R$ {0:N2}', Mode=OneWay}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>
                                        <Button Content="Remover" Background="Transparent" Foreground="Red" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" HorizontalAlignment="Right" Click="RemoverItem_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resumo do Pedido" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Total:" FontSize="16" Foreground="#555" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ValorTotal, StringFormat='R$ {0:N2}', Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="Finalizar Pedido" 
                            Background="#FFD700" 
                            Foreground="Black" 
                            FontWeight="Bold" 
                            Height="45" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Margin="0,20,0,0"
                            Click="FinalizarPedido_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>