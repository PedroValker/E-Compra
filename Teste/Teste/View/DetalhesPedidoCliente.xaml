<Window x:Class="Teste.View.DetalhesPedidoCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resumo do Pedido" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        FontFamily="Segoe UI, Tahoma, sans-serif">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding Recebedor, StringFormat='Pedido de {0}'}" FontSize="26" FontWeight="Black" Foreground="#111"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="📅 Data:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding DataDoPedido}" Foreground="#555" Margin="0,0,20,0"/>

                <TextBlock Text="📍 Entrega:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Endereco}" Foreground="#555" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="GridItens" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0" 
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                      RowHeight="40" Margin="0,-4,0,4">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="50">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nome da Cesta" Binding="{Binding Nome}" Width="150"/>

                    <DataGridTextColumn Header="Produtos na Cesta" Binding="{Binding Produtos}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='R$ {0:N2}'}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Forma de Pagamento:" FontWeight="SemiBold" Foreground="#333"/>
                <TextBlock Text="{Binding FormaPagamento}" Foreground="#555" Margin="0,0,0,10"/>

                <TextBlock Text="Observações:" FontWeight="SemiBold" Foreground="#333"/>
                <TextBlock Text="{Binding Observacoes}" Foreground="#555" TextWrapping="Wrap" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" MinWidth="200">
                <TextBlock Text="Total do Pedido" FontSize="14" Foreground="#777" HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding Total, StringFormat='R$ \{0:N2\}'}" FontSize="32" FontWeight="Black" Foreground="#002DB3" HorizontalAlignment="Right" Margin="0,-5,0,15"/>

                <Button Content="Fechar" Click="Fechar_Click" Height="40" Background="#212529" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
</Window>