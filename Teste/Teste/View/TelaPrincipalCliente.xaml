<Window x:Class="Teste.View.TelaPrincipalCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard - Cliente Basic"
        WindowState="Maximized"
        Background="#F2F2F2">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="Black"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1A2BE2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Background="White">

            <Grid Height="70" Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="VoltarInicio_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🛒" FontSize="22" Margin="0,0,5,0" Foreground="#1E22D8"/>
                        <TextBlock Text="Basic" FontSize="22" FontWeight="Bold" Foreground="#1E22D8"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="NomeUsuarioText" Grid.Column="1"
                           Text="Olá, Usuário" FontSize="18" FontWeight="SemiBold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Width="35" Height="35" Margin="5" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center"/>
                    </Button>

                    <Button Width="35" Height="35" Margin="5" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="VerCarrinho_Click">
                        <TextBlock Text="🛒" FontSize="16" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button Content="Início" Style="{StaticResource MenuButton}" Margin="5" Width="100" Click="VoltarInicio_Click"/>
                <Button Content="Faça seu Pedido" Style="{StaticResource PrimaryButton}" Margin="5" Width="223" Click="FaçaPedido"/>
                <Button Content="Assinatura" Style="{StaticResource MenuButton}" Margin="5" Width="158"/>
                <Button Content="Pedidos" Style="{StaticResource MenuButton}" Margin="5" Width="133"/>
                <Button Content="Sobre" Style="{StaticResource MenuButton}" Margin="5" Width="110"/>
                <Button Content="Contato" Style="{StaticResource MenuButton}" Margin="5" Width="134"/>
            </StackPanel>
        </StackPanel>

        <ContentControl x:Name="ConteudoPrincipal" Grid.Row="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border Margin="20" CornerRadius="10" ClipToBounds="True" Background="#E2E8F0" Height="250">
                        <Image Source="banner.jpg" Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Margin="30,10,30,30">
                        <TextBlock Text="Verifique nossos produtos" FontSize="20" FontWeight="Bold" Margin="10,0,10,20" HorizontalAlignment="Center"/>

                        <ItemsControl ItemsSource="{Binding ListaCestas}" HorizontalAlignment="Center">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="10" Margin="15" Padding="15" Width="280">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <StackPanel>

                                            <Border Background="#F3F4F6" Height="140" CornerRadius="8" Margin="0,0,0,10">
                                                <TextBlock Text="📦" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D1D5DB"/>
                                            </Border>

                                            <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Preco, StringFormat='R$ {0:N2}'}" Foreground="#555" Margin="0,5,0,0"/>

                                            <Button Content="Comprar" 
                                                Background="#FFD700" 
                                                Margin="0,15,0,0" 
                                                Height="35" 
                                                Cursor="Hand" 
                                                BorderThickness="0" 
                                                FontWeight="SemiBold"
                                                Click="ComprarCesta_Click"/>                
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </ContentControl>

        <Grid Grid.Row="2" Background="#1A2BE2">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🛒 Basic" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Contato: +55 11 8302-0238" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>