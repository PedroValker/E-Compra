<Window x:Class="Teste.View.TelaPrincipalCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard - Cliente Basic"
        WindowState="Maximized"
        Background="#F4F6F8"
        FontFamily="Segoe UI, Tahoma, sans-serif"
        Name="JanelaPrincipal">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2CC00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuItemText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="25,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#002DB3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2" Direction="270"/>
            </Border.Effect>

            <StackPanel HorizontalAlignment="Center" MaxWidth="1300" Width="{Binding ActualWidth, ElementName=JanelaPrincipal}">

                <Grid Margin="20,25,20,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="🛒 Basic" FontSize="32" FontWeight="Black" Foreground="#002DB3"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="R. Prefeita Adelle de Moraes - Cachoeira Paulista, SP ˅" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Medium" Foreground="#555"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="NomeUsuarioText" 
                                   Text="{Binding NomeUsuarioLogado}" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#333"
                                   VerticalAlignment="Center" 
                                   Margin="0,0,15,0"/>

                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0" ToolTip="Sair da Conta" Click="Logoff_Click">
                            <TextBlock Text="🚪" FontSize="24"/>
                        </Button>

                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Carrinho" Click="VerCarrinho_Click">
                            <TextBlock Text="🛒" FontSize="24"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Separator Background="#EEEEEE" Margin="0" Height="1"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,20">
                    <TextBlock Text="Início" Style="{StaticResource MenuItemText}" FontWeight="Bold" Foreground="#002DB3" MouseLeftButtonDown="VoltarInicio_Click"/>
                    <TextBlock Text="Faça seu Pedido" Style="{StaticResource MenuItemText}" FontWeight="Bold" Foreground="#555" MouseLeftButtonDown="FaçaPedido"/>
                    <TextBlock Text="Assinatura" Style="{StaticResource MenuItemText}" FontWeight="SemiBold" Foreground="#777"/>
                    <TextBlock Text="Pedidos" Style="{StaticResource MenuItemText}" FontWeight="Bold" Foreground="#555" MouseLeftButtonDown="Pedidos" />
                    <TextBlock Text="Sobre" Style="{StaticResource MenuItemText}" FontWeight="SemiBold" Foreground="#777"/>
                    <TextBlock Text="Entre em Contato" Style="{StaticResource MenuItemText}" FontWeight="SemiBold" Foreground="#777" MouseLeftButtonDown="EntreEmContato"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ContentControl x:Name="ConteudoPrincipal" Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" MaxWidth="1080" Width="{Binding ActualWidth, ElementName=JanelaPrincipal}" Margin="20,30,20,50">
                    <Grid Height="300" Margin="0,0,0,40">

                        <Border CornerRadius="16">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                              ShadowDepth="4"
                              Opacity="0.15"
                              Direction="270"
                              Color="Black"/>
                            </Border.Effect>

                            <Border.Background>
                                <ImageBrush ImageSource="pack://application:,,,/Dados/imagem/fundoteste.png"
                        Stretch="Fill"/>
                            </Border.Background>

                        </Border>

                    </Grid>

                    <StackPanel>
                        <TextBlock Text="Verifique nossos produtos" FontSize="30" FontWeight="Black" Foreground="#222" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                        <ItemsControl ItemsSource="{Binding ListaCestas}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" ItemWidth="340"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="16" Margin="15" Padding="25">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Opacity="0.08" ShadowDepth="5" Direction="270" Color="Black"/>
                                        </Border.Effect>

                                        <StackPanel>
                                            <Border Background="#F4F6F8"
        Height="250"
        CornerRadius="12"
        Margin="0,0,0,20"
        ClipToBounds="True">

                                                <Grid Margin="4">

                                                    <Image Source="{Binding ImagemCompleta}"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

                                                </Grid>

                                            </Border>

                                            <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="22" Foreground="#212529" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding Preco, StringFormat='R$ {0:N2}'}" FontSize="18" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,25"/>

                                            <Button Content="Comprar" 
                                                    Style="{StaticResource PrimaryButton}" 
                                                    Click="ComprarCesta_Click"
                                                    HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>

        <Border Grid.Row="2" Background="#1E22D8" Padding="0,20,0,5">
            <Grid MaxWidth="1200" Margin="40,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🛒 Basic" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                            <TextBlock Text="📞" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock Text="+55 11 8302-0238" Foreground="White" Opacity="0.85" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock Text="contato@basic.com" Foreground="White" Opacity="0.85" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Separator Grid.Row="1" Background="White" Opacity="0.15" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="2" Text="© 2024 Basic Cestas. Todos os direitos reservados." Foreground="White" Opacity="0.5" FontSize="12" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>