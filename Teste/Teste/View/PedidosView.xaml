<UserControl x:Class="View.PedidosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Teste.ViewModel">

	<UserControl.DataContext>
		<vm:PedidosViewModel/>
	</UserControl.DataContext>

	<Grid Margin="20">

		<!-- LINHAS -->
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- filtro -->
			<RowDefinition Height="*"/>
			<!-- conteúdo -->
		</Grid.RowDefinitions>

		<!-- COLUNAS -->
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="3*" />
			<ColumnDefinition Width="1.5*" />
		</Grid.ColumnDefinitions>

		<!-- 🔍 FILTRO -->
		<StackPanel Orientation="Horizontal"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="0 0 0 10">

			<TextBlock Text="Filtrar por status:"
                       VerticalAlignment="Center"
                       Margin="0 0 10 0"/>

			<ComboBox Width="150"
                      ItemsSource="{Binding StatusDisponiveis}"
                      SelectedItem="{Binding StatusSelecionado}"/>
		</StackPanel>

		<!-- 📋 ESQUERDA -->
		<StackPanel Grid.Row="1" Grid.Column="0">

			<TextBlock Text="Histórico de Pedidos"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 0 0 10"/>

			<DataGrid ItemsSource="{Binding PedidosView}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">

                <DataGrid ItemsSource="{Binding PedidosView}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          Margin="0,10,0,0">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Produto"
                            Binding="{Binding Produto}"
                            Width="*"/>

                        <DataGridTextColumn Header="Status"
                            Binding="{Binding Status}"
                            Width="150"/>

                        <DataGridTextColumn Header="Valor"
                            Binding="{Binding Valor, StringFormat=C}"
                            Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- (colunas mantidas iguais) -->

			</DataGrid>
		</StackPanel>

		<!-- 📊 DIREITA -->
		<StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Margin="20 0 0 0">

			<Border Background="#F5F5F5" Padding="15" CornerRadius="10">
				<StackPanel>

					<TextBlock Text="{Binding Total, StringFormat=Total: {0:C}}"
                               FontWeight="Bold"
                               FontSize="16"/>

					<TextBlock Text="Resumo do pedido:"
                               Margin="0 10 0 5"/>

					<ItemsControl ItemsSource="{Binding Resumo}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<TextBlock>
									<Run Text="{Binding Quantidade}"/>
									<Run Text=" "/>
									<Run Text="{Binding Nome}"/>
								</TextBlock>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<Border Background="#F5F5F5"
                    Padding="10"
                    CornerRadius="10"
                    Margin="0 10 0 0">

				<TextBlock Text="{Binding Observacoes}" TextWrapping="Wrap"/>
			</Border>

		</StackPanel>

	</Grid>
</UserControl>