<UserControl x:Class="Teste.View.PedidosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="58"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="Padding" Value="16,12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#334155"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnVisualizarStyle" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Meus Pedidos" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Acompanhe o status e histórico das suas compras." FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <TextBlock x:Name="AbaPendentesTexto" Text="Pendentes" MouseLeftButtonDown="AbaPendentes_Click" Cursor="Hand" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,24,0"/>
                <TextBlock x:Name="AbaCaminhoTexto" Text="A Caminho" MouseLeftButtonDown="AbaCaminho_Click" Cursor="Hand" FontWeight="Normal" Foreground="#94A3B8" Margin="0,0,24,0"/>
                <TextBlock x:Name="AbaHistoricoTexto" Text="Histórico" MouseLeftButtonDown="AbaHistorico_Click" Cursor="Hand" FontWeight="Normal" Foreground="#94A3B8"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="6" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="TabelaDePedidos" ItemsSource="{Binding ListaPedidosPendentes}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding NomePedido}" Width="130"/>
                    <DataGridTextColumn Header="Data Entrega" Binding="{Binding DataEntrega, StringFormat={}{0:dd/MM/yyyy}}" Width="120"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat='R$ {0:N2}'}" Width="110"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>

                    <DataGridTemplateColumn Header="Ações" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Ver Detalhes" Style="{StaticResource BtnVisualizarStyle}" Click="VerDetalhes_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>