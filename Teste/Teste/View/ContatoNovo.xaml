<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Teste.View.ContatoNovo"
             Background="#F2F2F2"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch" Width="1067">

    <Grid Margin="40">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <StackPanel HorizontalAlignment="Center"
                    Margin="0,0,0,40">

            <TextBlock Text="Sobre Nós"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1E1E1E"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Estamos sempre prontos para atender você da melhor forma possível."
                       FontSize="15"
                       Foreground="#666"
                       TextAlignment="Center"
                       Width="500"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- CONTEÚDO -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- TEXTO SOBRE -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="20"
                    Padding="35"
                    Margin="0,0,25,0">

                <StackPanel>

                    <TextBlock Text="Quem Somos"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E22D8"
                               Margin="0,0,0,20" Width="149"/>

                    <TextBlock TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="#444"
                               LineHeight="26" Height="218" Width="359"><Run Text="Nossa empresa busca oferecer a melhor experiência para nossos clientes, unindo qualidade, inovação e atendimento personalizado. Trabalhamos com dedicação para entregar soluções modernas e eficientes, sempre priorizando confiança, agilidade e excelência em cada detalhe. Caso tenha dúvidas, sugestões ou precise de suporte, nossa equipe estará pronta para ajudar você."/></TextBlock>

                </StackPanel>

            </Border>

            <!-- CARD CONTATO -->
            <Button Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand">

                <Border Background="White"
                        CornerRadius="20"
                        Padding="20">

                    <StackPanel HorizontalAlignment="Center">

                        <!-- IMAGEM -->
                        <Border Width="220"
                                Height="220"
                                CornerRadius="20"
                                ClipToBounds="True"
                                Margin="0,0,0,20">

                            <Image Source="/Images/contato.png"
                                   Stretch="UniformToFill"/>
                        </Border>

                        <TextBlock Text="Entre em Contato"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#1E1E1E"/>

                        <TextBlock Text="Clique aqui para falar conosco"
                                   FontSize="14"
                                   Foreground="#666"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

            </Button>

        </Grid>

    </Grid>

</UserControl>