<UserControl x:Class="Teste.View.EditarPerfilCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch">

    <!-- SCROLL PRINCIPAL -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="25"
              MinWidth="900">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TÍTULO -->
            <TextBlock Grid.Row="0"
                       Text="Editar Perfil"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <!-- CONTEÚDO -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========================================= -->
                <!-- PAINEL ESQUERDO -->
                <!-- ========================================= -->

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="14"
                        Padding="25"
                        VerticalAlignment="Top">

                    <StackPanel>

                        <!-- FOTO -->
                        <TextBlock Text="Foto de Perfil"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <Border Width="180"
                                Height="180"
                                CornerRadius="90"
                                BorderThickness="3"
                                BorderBrush="#E3E6EA"
                                ClipToBounds="True"
                                HorizontalAlignment="Center">

                            <Image x:Name="ImagemPerfil"
                                   Stretch="Fill"/>

                        </Border>

                        <!-- BOTÃO FOTO -->
                        <Button Content="Alterar Foto"
                                Height="45"
                                Margin="0,25,0,0"
                                Background="#1E22D8"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="14"
                                Cursor="Hand"
                                BorderThickness="0">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>

                        </Button>

                        <!-- INFO -->
                        <TextBlock Text="Informações da Conta"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,40,0,18"/>

                        <!-- ID -->
                        <TextBlock Text="ID do Usuário"
                                   FontWeight="SemiBold"
                                   Foreground="#555"/>

                        <Border Background="#F8F9FA"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,6,0,15">

                            <TextBlock Text="{Binding Id}"
                                       FontSize="14"/>

                        </Border>

                        <!-- DATA -->
                        <TextBlock Text="Conta Criada em"
                                   FontWeight="SemiBold"
                                   Foreground="#555"/>

                        <Border Background="#F8F9FA"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,6,0,0">

                            <TextBlock Text="{Binding DataCriacao}"
                                       FontSize="14"/>

                        </Border>

                    </StackPanel>

                </Border>

                <!-- ========================================= -->
                <!-- FORMULÁRIO -->
                <!-- ========================================= -->

                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="14"
                        Padding="35">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- TÍTULO -->
                        <TextBlock Grid.Row="0"
                                   Text="Dados Pessoais"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,30"/>

                        <!-- NOME -->
                        <StackPanel Grid.Row="1"
                                    Margin="0,0,0,18">

                            <TextBlock Text="Nome"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox x:Name="TxtNome"
                                     Height="42"
                                     Padding="10"
                                     FontSize="14"
                                     Text="{Binding Nome}"/>

                        </StackPanel>

                        <!-- EMAIL -->
                        <StackPanel Grid.Row="2"
                                    Margin="0,0,0,18">

                            <TextBlock Text="Email"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox x:Name="TxtEmail"
                                     Height="42"
                                     Padding="10"
                                     FontSize="14"
                                     Text="{Binding Email}"/>

                        </StackPanel>

                        <!-- TELEFONE -->
                        <StackPanel Grid.Row="3"
                                    Margin="0,0,0,18">

                            <TextBlock Text="Telefone"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox x:Name="TxtTelefone"
                                     Height="42"
                                     Padding="10"
                                     FontSize="14"
                                     Text="{Binding Telefone}"/>

                        </StackPanel>

                        <!-- SENHA -->
                        <StackPanel Grid.Row="4"
                                    Margin="0,0,0,25">

                            <TextBlock Text="Nova Senha"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <PasswordBox x:Name="TxtSenha"
                                         Height="42"
                                         Padding="10"
                                         FontSize="14"/>

                        </StackPanel>

                        <!-- BOTÕES -->
                        <Grid Grid.Row="5"
                              Margin="0,10,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- CANCELAR -->
                            <Button Grid.Column="0"
                                    Content="Cancelar"
                                    Height="45"
                                    Background="#E9ECEF"
                                    Foreground="#222"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Cancelar_Click">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>

                            </Button>

                            <!-- SALVAR -->
                            <Button Grid.Column="2"
                                    Content="Salvar Alterações"
                                    Height="45"
                                    Background="#FFD700"
                                    Foreground="#111"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Salvar_Click">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>

                            </Button>

                        </Grid>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</UserControl>