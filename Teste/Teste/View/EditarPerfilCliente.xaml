<UserControl x:Class="Teste.View.EditarPerfilCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch">

    <Grid Margin="30">

        <!-- TÍTULO -->
        <TextBlock Text="Editar Perfil"
                   FontSize="30"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LADO ESQUERDO -->
            <StackPanel Grid.Column="0"
                        Margin="20">

                <TextBlock Text="Foto de Perfil"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- FOTO -->
                <Border Width="170"
                        Height="170"
                        CornerRadius="85"
                        BorderThickness="3"
                        BorderBrush="#E0E0E0"
                        ClipToBounds="True"
                        HorizontalAlignment="Center">

                    <Image x:Name="ImagemPerfil"
                           Stretch="Fill"/>

                </Border>

                <!-- BOTÃO -->
                <Button Content="Alterar Foto"
                        Height="42"
                        Margin="0,25,0,0"
                        Background="#1E22D8"
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand"
                        BorderThickness="0"
                        Click="AlterarFoto_Click"/>

                <!-- INFO -->
                <TextBlock Text="Informações da Conta"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,40,0,15"/>

                <TextBlock Text="ID do Usuário"/>
                <Border Background="White"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,5">

                    <TextBlock Text="{Binding Id}"/>

                </Border>

                <TextBlock Text="Conta Criada em"
                           Margin="0,15,0,0"/>

                <Border Background="White"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,5">

                    <TextBlock Text="{Binding DataCriacao}"/>

                </Border>

            </StackPanel>

            <!-- FORMULÁRIO -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="30"
                    Margin="20">

                <StackPanel>

                    <TextBlock Text="Dados Pessoais"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,25"/>

                    <!-- NOME -->
                    <TextBlock Text="Nome"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="TxtNome"
                             Height="40"
                             Margin="0,8,0,20"
                             Text="{Binding Nome}"/>

                    <!-- EMAIL -->
                    <TextBlock Text="Email"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="TxtEmail"
                             Height="40"
                             Margin="0,8,0,20"
                             Text="{Binding Email}"/>

                    <!-- TELEFONE -->
                    <TextBlock Text="Telefone"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="TxtTelefone"
                             Height="40"
                             Margin="0,8,0,20"
                             Text="{Binding Telefone}"/>

                    <!-- SENHA -->
                    <TextBlock Text="Nova Senha"
                               FontWeight="SemiBold"/>

                    <PasswordBox x:Name="TxtSenha"
                                 Height="40"
                                 Margin="0,8,0,25"/>

                    <!-- BOTÕES -->
                    <Grid Margin="0,20,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancelar"
                                Height="45"
                                Margin="0,0,10,0"
                                Background="#E9ECEF"
                                Foreground="#222"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Cancelar_Click"/>

                        <Button Grid.Column="1"
                                Content="Salvar Alterações"
                                Height="45"
                                Margin="10,0,0,0"
                                Background="#FFD700"
                                Foreground="#111"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Salvar_Click"/>

                    </Grid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</UserControl>