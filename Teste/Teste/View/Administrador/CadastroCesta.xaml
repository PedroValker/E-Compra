<UserControl x:Class="Teste.View.CadastroCesta"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <UserControl.Resources>
        <Style x:Key="InputCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Montar Cestas Básicas" FontSize="28" FontWeight="Bold" Foreground="#1F2937"/>
                <TextBlock Text="Crie categorias de cestas agrupando produtos do seu estoque." Foreground="#6B7280" FontSize="15" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nome da Cesta" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                        <Border Style="{StaticResource InputCard}">
                            <TextBox x:Name="NomeCestaBox" BorderThickness="0" Background="Transparent" FontSize="14"/>
                        </Border>
                        <TextBlock Text="Imagem da Cesta" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>

                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource InputCard}" Margin="0,0,10,0">
                                <TextBox x:Name="ImagemPathBox" 
                 BorderThickness="0" 
                 Background="Transparent" 
                 FontSize="14"
                 IsReadOnly="True"/>
                            </Border>

                            <Button Grid.Column="1"
            Content="📷 Selecionar"
            Background="#6366F1"
            Foreground="White"
            FontWeight="Bold"
            BorderThickness="0"
            Padding="12,0"
            Cursor="Hand"
            Click="SelecionarImagem_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>


                        <Image x:Name="PreviewImagem"
       Height="116"
       Stretch="UniformToFill"
       Margin="0,0,0,15" Width="152"/>
                        <TextBlock Text="Preço da Cesta (R$)" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                        <Border Style="{StaticResource InputCard}">
                            <TextBox x:Name="PrecoCestaBox" BorderThickness="0" Background="Transparent" FontSize="14"/>
                        </Border>

                        <Separator Margin="0,10,0,20" Background="#E5E7EB"/>

                        <TextBlock Text="Adicionar Produto do Estoque" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource InputCard}" Margin="0,0,10,0">
                                <ComboBox x:Name="ProdutosComboBox" BorderThickness="0" Background="Transparent" FontSize="14" DisplayMemberPath="Nome"/>
                            </Border>

                            <Button Grid.Column="1" Content="Adicionar" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,0" Cursor="Hand" Click="AdicionarItem_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Itens contidos nesta Cesta:" Foreground="#1F2937" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <ListView x:Name="ListaItensAtuais" Height="150" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Produto" DisplayMemberBinding="{Binding Nome}" Width="150"/>
                                    <GridViewColumn Header="Peso" DisplayMemberBinding="{Binding Peso}" Width="80"/>
                                    <GridViewColumn Header="Preco" DisplayMemberBinding="{Binding Preco}" Width="80"/>
                                    <GridViewColumn Header="Remover" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="❌" Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand" Click="RemoverItemDaCesta_Click"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Button Content="💾 Salvar Cesta Básica" Background="#1E22D8" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="0,12" Margin="0,15,0,0" Cursor="Hand" Click="SalvarCesta_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Cestas Cadastradas no Sistema" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>
                    <ListView x:Name="ListaCestas" Height="250" BorderBrush="#D1D5DB" BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Nome da Cesta" DisplayMemberBinding="{Binding Nome}" Width="250"/>
                                <GridViewColumn Header="Preço (R$)" DisplayMemberBinding="{Binding Preco}" Width="150"/>

                                <GridViewColumn Header="Ações" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="👁️ Ver Itens" Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,0,5,0" Cursor="Hand" Click="VerItens_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>

                                                <Button Content="✏️ Editar" Background="#F59E0B" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,0,5,0" Cursor="Hand" Click="EditarCesta_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>

                                                <Button Content="🗑️ Excluir" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="8,4" Cursor="Hand" Click="ExcluirCesta_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>