<UserControl x:Class="Teste.View.HomeAdministrador"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Dashboard"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

            <TextBlock x:Name="BoasVindasTexto"
                       Text="Bem-vindo de volta! Aqui está o resumo de hoje."
                       FontSize="15"
                       Foreground="#6B7280"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Total de Pedidos"
                               Foreground="#6B7280"
                               FontSize="14"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TxtPedidos"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Pedidos a Entregar"
                               Foreground="#6B7280"
                               FontSize="14"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TxtPedidosAEntregar"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#D97706"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Pagamentos Pendentes"
                               Foreground="#6B7280"
                               FontSize="14"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TxtPagPendentes"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#EF4444"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="25"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Resumo das Cestas"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Cesta Econômica"
                                   FontSize="15"
                                   Foreground="#4B5563"/>

                        <TextBlock x:Name="TxtVendas1"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Background="#F3F4F6"
                               Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Cesta Família"
                                   FontSize="15"
                                   Foreground="#4B5563"/>

                        <TextBlock x:Name="TxtVendas2"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Background="#F3F4F6"
                               Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Cesta Especial"
                                   FontSize="15"
                                   Foreground="#4B5563"/>

                        <TextBlock  x:Name="TxtVendas3"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Background="#F3F4F6"
                               Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Cesta Premium"
                                   FontSize="15"
                                   Foreground="#4B5563"/>

                        <TextBlock  x:Name="TxtVendas4"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="25"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    VerticalAlignment="Top">

                <StackPanel>

                    <TextBlock Text="Faturamento Mensal"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="TxtFaturamento"
                               FontSize="30"
                               FontWeight="ExtraBold"
                               Foreground="#10B981"
                               Margin="0,0,0,5"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>