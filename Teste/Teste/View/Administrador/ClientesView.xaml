<UserControl x:Class="Teste.View.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">

            <TextBlock Text="Clientes"
                       FontSize="28"
                       FontWeight="Bold"/>

            <TextBlock Text="Visualize os clientes cadastrados e seus pedidos."
                       FontSize="15"
                       Foreground="Gray"/>

        </StackPanel>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <!-- CLIENTES -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">

                <ListBox ItemsSource="{Binding Clientes}"
                         SelectedItem="{Binding ClienteSelecionado}">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <StackPanel Margin="5">

                                <TextBlock Text="{Binding Nome}"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Email}"
                                           FontSize="12"/>

                            </StackPanel>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

            </Border>

            <!-- PEDIDOS -->

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="15">

                <StackPanel>

                    <TextBlock Text="Histórico de Pedidos"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <DataGrid ItemsSource="{Binding PedidosCliente}"
                              AutoGenerateColumns="False">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Pedido"
                                                Binding="{Binding IdPedido}"/>

                            <DataGridTextColumn Header="Data"
                                                Binding="{Binding DataDoPedido}"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"/>

                            <DataGridTextColumn Header="Pagamento"
                                                Binding="{Binding Pago}"/>

                            <DataGridTextColumn Header="Total"
                                                Binding="{Binding Total}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</UserControl>