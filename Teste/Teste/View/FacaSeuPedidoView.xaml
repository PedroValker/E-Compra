<UserControl x:Class="Teste.View.FacaSeuPedidoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F59E0B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="40,35,40,15">
            <TextBlock Text="Escolha sua cesta ideal"
                       FontSize="32"
                       FontWeight="Black"
                       Foreground="#111827"/>
            <TextBlock Text="Selecionamos os melhores produtos com carinho para você."
                       FontSize="16"
                       Foreground="#6B7280"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,0,40">
            <ItemsControl ItemsSource="{Binding ListaCestas}" Margin="25,0">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Margin="15" Background="White" CornerRadius="16" Padding="15">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.06"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#F3F4F6" CornerRadius="12" Margin="0,0,0,15" ClipToBounds="True">
                                    <Image Source="{Binding ImagemCompleta}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="10"/>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding Nome}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="2"
                                           Text="{Binding Preco, StringFormat='R$ \{0:N2\}'}"
                                           FontSize="22"
                                           FontWeight="Black"
                                           Foreground="#2563EB" 
                                           Margin="0,0,0,15"/>

                                <Button Grid.Row="3"
                                        Content="Comprar Agora"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="ComprarCesta_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>